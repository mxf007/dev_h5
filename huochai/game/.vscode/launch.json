{
    "configurations": [
        {
            "type": "Egret",
            "request": "launch",
            "name": "Egret Debugger",
            "url": "http://localhost:${command:WebsitePort}",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "userDataDir": "${tmpdir}"
        },

        {
            "type": "Egret",
            "request": "launch",
            "name": "Egret WebpackDevServer Debugger",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "egret: build"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Egret Debug(chrome)",
            "url": "http://127.0.0.1:7000/index.html",
            "webRoot": "${workspaceFolder}",
            "presentation": {
                "hidden": false,
                "group": "egret-helper"
            }
        }
    ],
    "version": "0.2.0"
}